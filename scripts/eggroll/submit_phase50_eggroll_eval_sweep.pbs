#!/usr/bin/env bash
# PBS (CX3): EGGROLL checkpoint eval sweep using Phase12 vector eval.
#PBS -N p50eggeval
#PBS -l select=1:ncpus=8:mem=32gb:ngpus=1:gpu_type=RTX6000
#PBS -l walltime=00:35:00
#PBS -j oe
#PBS -o phase50_eggroll_eval_sweep_pbs.out

set -euo pipefail

if [[ -f /etc/profile.d/modules.sh ]]; then . /etc/profile.d/modules.sh; fi
module purge >/dev/null 2>&1 || true
module load tools/prod
module load Python/3.12.3-GCCcore-13.3.0
module load Mesa/24.1.3-GCCcore-13.3.0

PROJECT_ROOT="$(cd "${PBS_O_WORKDIR:-/rds/general/user/aa6622/home/project}" && pwd)"
export SLURM_SUBMIT_DIR="${PROJECT_ROOT}"
cd "${PROJECT_ROOT}"
source "${PROJECT_ROOT}/scripts/slurm/common_env.sh"
slurm_resolve_project_root "scripts/grpo/eval_phase12_checkpoint_sweep.py"
slurm_export_pythonpath
slurm_export_hf_torch_cache "phase50-eggroll-eval-sweep"

export MUJOCO_GL="${MUJOCO_GL:-osmesa}"
export PYOPENGL_PLATFORM="${PYOPENGL_PLATFORM:-osmesa}"
export LIBGL_ALWAYS_SOFTWARE="${LIBGL_ALWAYS_SOFTWARE:-1}"
export PATH="${PATH:-/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin}"
export HF_HUB_OFFLINE="${HF_HUB_OFFLINE:-0}"
export TRANSFORMERS_OFFLINE="${TRANSFORMERS_OFFLINE:-0}"
export SMOLVLA_METAWORLD_RESET_MODE="${SMOLVLA_METAWORLD_RESET_MODE:-random_seeded}"

EGGROLL_PYTHON="${EGGROLL_PYTHON:-/rds/general/user/aa6622/home/.envs/lerobot_mw_py312/bin/python}"
if [[ ! -x "${EGGROLL_PYTHON}" ]]; then
  echo "error: no usable EGGROLL_PYTHON=${EGGROLL_PYTHON}" >&2
  exit 2
fi
BASE_CKPT="${PHASE50_CHECKPOINT:-/rds/general/user/aa6622/home/.cache/huggingface/hub/models--jadechoghari--smolvla_metaworld/snapshots/ef3089ecb84eeeb7d33fedab24f6c76180a68900}"
TASK="${PHASE50_TASK:-push-v3}"
CAL_ROOT="${PHASE50_CALIBRATION_ROOT:-${PROJECT_ROOT}/artifacts/phase50_eggroll_calibration/${TASK}}"
RUN_DIR="${PHASE50_RUN_DIR:-}"
if [[ -z "${RUN_DIR}" && -f "${CAL_ROOT}/train_run_dir.txt" ]]; then
  RUN_DIR="$(<"${CAL_ROOT}/train_run_dir.txt")"
fi
if [[ -z "${RUN_DIR}" || ! -d "${RUN_DIR}" ]]; then
  echo "error: RUN_DIR missing or not a directory: ${RUN_DIR}" >&2
  exit 2
fi

MAX_UPDATE="${PHASE50_MAX_UPDATE:-}"
if [[ -z "${MAX_UPDATE}" ]]; then
  MAX_UPDATE="$("${EGGROLL_PYTHON}" - "${RUN_DIR}" <<'PY'
from pathlib import Path
import re, sys
vals=[]
for p in (Path(sys.argv[1])/"checkpoints").glob("update_*.pt"):
    m=re.match(r"update_(\d+)\.pt$", p.name)
    if m:
        vals.append(int(m.group(1)))
print(max(vals) if vals else 0)
PY
)"
fi
ALLOW_BASE_EVAL="${PHASE50_ALLOW_BASE_EVAL:-0}"
if [[ "${MAX_UPDATE}" -lt 10 && "${ALLOW_BASE_EVAL}" != "1" ]]; then
  echo "error: no eval checkpoint >= update_0010 in ${RUN_DIR}" >&2
  exit 2
fi

SWEEP_NAME="${PHASE50_SWEEP_NAME:-eval_every10}"
MIN_UPDATE="${PHASE50_MIN_UPDATE:-10}"
if [[ "${ALLOW_BASE_EVAL}" == "1" ]]; then
  MIN_UPDATE="${PHASE50_MIN_UPDATE:-0}"
  MAX_UPDATE="${PHASE50_MAX_UPDATE:-0}"
fi
STRIDE="${PHASE50_STRIDE:-10}"
EPISODES="${PHASE50_EVAL_EPISODES:-10}"

"${EGGROLL_PYTHON}" scripts/grpo/eval_phase12_checkpoint_sweep.py \
  --base-checkpoint "${BASE_CKPT}" \
  --run-dir "${RUN_DIR}" \
  --task "${TASK}" \
  --episodes "${EPISODES}" \
  --eval-seed-start "${PHASE50_EVAL_SEED_START:-1000}" \
  --sweep-name "${SWEEP_NAME}" \
  --min-update "${MIN_UPDATE}" \
  --max-update "${MAX_UPDATE}" \
  --stride "${STRIDE}" \
  --execution-mode "${PHASE50_EVAL_EXECUTION_MODE:-inprocess_vector}" \
  --n-envs "${PHASE50_EVAL_N_ENVS:-3}" \
  --rollout-execution "${PHASE50_EVAL_ROLLOUT_EXECUTION:-vector_sync}" \
  --max-steps "${PHASE50_EVAL_MAX_STEPS:-120}"

test -f "${RUN_DIR}/${SWEEP_NAME}/eval_sweep_summary.json"
echo "PHASE50_EGGROLL_EVAL_SWEEP_DONE run_dir=${RUN_DIR} sweep=${SWEEP_NAME}"
