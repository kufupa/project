#!/usr/bin/env bash
#PBS -N p11p128smk
#PBS -l select=1:ncpus=96:mem=128gb:ngpus=1:gpu_type=RTX6000
#PBS -l walltime=00:30:00
#PBS -j oe
#PBS -o logs/pbs/grpo/phase11_pop128_rolloutpbs32_smoke_u1.out

set -euo pipefail
if [[ -f /etc/profile.d/modules.sh ]]; then . /etc/profile.d/modules.sh; fi
module purge >/dev/null 2>&1 || true
module load tools/prod
module load Python/3.12.3-GCCcore-13.3.0
module load Mesa/24.1.3-GCCcore-13.3.0
cd /rds/general/user/aa6622/home/project

RUN_DIR="artifacts/phase11_pushv3_pop128_rolloutpbs32_smoke_u1"
BASE_CKPT="/rds/general/user/aa6622/home/.cache/huggingface/hub/models--jadechoghari--smolvla_metaworld/snapshots/ef3089ecb84eeeb7d33fedab24f6c76180a68900"
PYTHON_BIN="${GRPO_PYTHON:-/rds/general/user/aa6622/home/.envs/lerobot_mw_py312/bin/python}"
GPU_TELEMETRY_INTERVAL="${GPU_TELEMETRY_INTERVAL:-5}"
GPU_TELEMETRY_DIR="${RUN_DIR}/gpu_telemetry/train"

mkdir -p logs/pbs/grpo "${RUN_DIR}" "${GPU_TELEMETRY_DIR}"

export PYTHONPATH=src
export MUJOCO_GL=egl
export PYOPENGL_PLATFORM=egl
unset LIBGL_ALWAYS_SOFTWARE
export HF_HUB_OFFLINE=1
export TRANSFORMERS_OFFLINE=1
export SMOLVLA_METAWORLD_RESET_MODE="${SMOLVLA_METAWORLD_RESET_MODE:-random_seeded}"
export SMOLVLA_GRPO_ASYNC_MP_CONTEXT=forkserver
export PYTHONUNBUFFERED=1
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1
export TOKENIZERS_PARALLELISM=false
export AGENT_DEBUG_MEM=1
export AGENT_DEBUG_RUN_ID=phase11_pop128_smoke

if [[ ! -x "${PYTHON_BIN}" ]]; then
  echo "error: missing PYTHON_BIN=${PYTHON_BIN}" >&2
  exit 2
fi
if [[ ! -d "${BASE_CKPT}" ]]; then
  echo "error: missing BASE_CKPT=${BASE_CKPT}" >&2
  exit 2
fi

NVIDIA_SMI_PID=""
stop_gpu_telemetry() {
  local status=$?
  set +e
  if [[ -n "${NVIDIA_SMI_PID}" ]] && kill -0 "${NVIDIA_SMI_PID}" >/dev/null 2>&1; then
    kill "${NVIDIA_SMI_PID}" >/dev/null 2>&1 || true
    wait "${NVIDIA_SMI_PID}" >/dev/null 2>&1 || true
  fi
  if command -v nvidia-smi >/dev/null 2>&1; then
    nvidia-smi > "${GPU_TELEMETRY_DIR}/nvidia_smi_end.txt" 2>&1 || true
  fi
  if [[ -f "${GPU_TELEMETRY_DIR}/nvidia_smi_samples.csv" ]]; then
    "${PYTHON_BIN}" scripts/grpo/summarize_phase58_gpu_telemetry.py \
      --csv "${GPU_TELEMETRY_DIR}/nvidia_smi_samples.csv" \
      --output "${GPU_TELEMETRY_DIR}/gpu_telemetry_summary.json" || true
  fi
  exit "${status}"
}

start_gpu_telemetry() {
  if command -v nvidia-smi >/dev/null 2>&1; then
    nvidia-smi > "${GPU_TELEMETRY_DIR}/nvidia_smi_start.txt" 2>&1 || true
    nvidia-smi \
      --query-gpu=timestamp,index,uuid,name,utilization.gpu,utilization.memory,memory.used,memory.total,power.draw,temperature.gpu \
      --format=csv,nounits \
      -l "${GPU_TELEMETRY_INTERVAL}" \
      > "${GPU_TELEMETRY_DIR}/nvidia_smi_samples.csv" \
      2> "${GPU_TELEMETRY_DIR}/nvidia_smi_samples.err" &
    NVIDIA_SMI_PID=$!
  fi
}

trap stop_gpu_telemetry EXIT
start_gpu_telemetry

echo "[phase11-pop128-smoke] train u1 g128 rpbs32 lpbs32 job=${PBS_JOBID:-local}"
"${PYTHON_BIN}" scripts/grpo/train_phase11_env_on_policy_grpo.py \
  --checkpoint "${BASE_CKPT}" \
  --output-dir "${RUN_DIR}" \
  --task push-v3 \
  --env-backend official_lerobot \
  --rollout-execution vector_async \
  --async-start-method forkserver \
  --group-size 128 \
  --max-steps 120 \
  --num-updates 1 \
  --save-every 1 \
  --action-chunk-size 5 \
  --chunk-size 5 \
  --lr 5e-6 \
  --clip-eps 0.1 \
  --logprob-recompute-mode batched \
  --logprob-batch-size 32 \
  --rollout-policy-batch-size 16 \
  --run-label pop128_rolloutpbs32_smoke_u1

test -f "${RUN_DIR}/train_manifest.json"
test -f "${RUN_DIR}/progress.jsonl"
test -f "${RUN_DIR}/checkpoints/update_0001.pt"
"${PYTHON_BIN}" - <<'PY'
import json
from pathlib import Path

run_dir = Path("artifacts/phase11_pushv3_pop128_rolloutpbs32_smoke_u1")
rows = [json.loads(line) for line in (run_dir / "progress.jsonl").read_text().splitlines() if line.strip()]
if not rows:
    raise SystemExit("progress.jsonl empty")
last = rows[-1]
assert int(last["group_size"]) == 128
assert int(last["rollout_policy_batch_size"]) == 16
assert int(last["logprob_batch_size"]) == 32
assert int(last["num_loss_units"]) > 0
assert last.get("skipped") is not True
for key in ("ratio_clip_fraction", "approx_kl", "ratio_max", "log_std_mean"):
    assert key in last, key
print("PHASE11_POP128_ROLLOUTPBS32_SMOKE_OK", run_dir)
PY
