# Example environment values for model/checkpoint locations and cache layout.
# Copy this file to `paths.local.env`, update values for your machine, then source it:
#   source docs/paths.example.env
# (This is shell assignment syntax intended to be sourced.)

# Core project paths
export PROJECT_ROOT=/absolute/path/to/project
export ARTIFACTS_DIR=/absolute/path/to/project/artifacts
export DATA_DIR=/absolute/path/to/project/data
export RUNS_DIR=/absolute/path/to/project/runs
export OUTPUTS_DIR=/absolute/path/to/project/outputs

# Model paths
export SMOLVLA_MODEL_PATH=/absolute/path/to/project/checkpoints/smolvla_vggflow.pt
export SMOLVLA_INIT_CHECKPOINT=jadechoghari/smolvla_metaworld
export JEPA_MODEL_PATH=/absolute/path/to/project/checkpoints/jepa.pt
export POLICY_PATH=/absolute/path/to/project/checkpoints/policy.ckpt
export VOXEL_BACKBONE_PATH=/absolute/path/to/project/checkpoints/voxel_backbone.pt
export SMOLVLA_LEROBOT_ENV_DIR=/absolute/path/to/.envs/lerobot_mw_py310
export SMOLVLA_ARTIFACT_ROOT=/absolute/path/to/project/artifacts
export SMOLVLA_PYTHON_BIN=/absolute/path/to/.envs/lerobot_mw_py310/bin/python
export SMOLVLA_PREFLIGHT_OUTPUT_ROOT=/absolute/path/to/project/artifacts/phase07_smolvla_baseline/preflight
export SMOLVLA_MAX_STEPS=120
export SMOLVLA_POLICY_DEVICE=auto
export SMOLVLA_EVAL_MODE=parity
export SMOLVLA_METAWORLD_CAMERA_NAME=corner2
export SMOLVLA_FLIP_CORNER2=true
export SMOLVLA_LOAD_VLM_WEIGHTS=true
export SMOLVLA_PARITY_OUTPUT_ROOT=/absolute/path/to/project/artifacts/phase07_smolvla_baseline/parity

# Cache layout
export PYTHONPATH_CACHE_DIR=/absolute/path/to/project/.cache/python
export MODEL_CACHE_DIR=/absolute/path/to/project/.cache/models
export HF_HOME=/absolute/path/to/project/.cache/huggingface
export TORCH_HOME=/absolute/path/to/project/.cache/torch
export WANDB_CACHE_DIR=/absolute/path/to/project/.cache/wandb
